# Azure AI Foundry Configuration
# Copy this file to .env.local and fill in your values

# Your Azure AI Foundry project endpoint
# Find this in: Azure AI Foundry portal > Project > Overview > Endpoint
VITE_AZURE_FOUNDRY_ENDPOINT=https://your-project.services.ai.azure.com

# Your Azure AI Foundry API key
# Find this in: Azure AI Foundry portal > Project > Settings > API keys
VITE_AZURE_FOUNDRY_API_KEY=your-api-key-here

# Name of your deployed model (e.g., gpt-4o, gpt-35-turbo)
# Find this in: Azure AI Foundry portal > Deployments
VITE_AZURE_FOUNDRY_DEPLOYMENT=gpt-4o
