# Playground Frontend Configuration
# Copy this file to .env.local and fill in your values
#
# The playground only needs to know the URL of the backend API server.
# All AI/LLM credentials (Azure AI Foundry keys, OpenAI keys, etc.) are
# configured exclusively on the server side in appsettings.json or via
# server environment variables — they never belong here.

# URL of the backend API server (used by the Vite dev proxy)
# In production the frontend is served from the same origin as the API,
# so this variable is only needed during local development.
# NOTE: use https:// in production deployments.
VITE_API_BASE_URL=http://localhost:5163
